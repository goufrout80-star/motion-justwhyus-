# Google Cloud project with Vertex AI enabled
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Path to your service account JSON key (downloaded from GCP console)
# The service account needs the "Vertex AI User" role.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Model to use for generation
GEMINI_MODEL=gemini-omni-flash-preview

# Server port
PORT=8787

# Comma-separated list of allowed origins for CORS (client dev server)
CLIENT_ORIGIN=http://localhost:5173
