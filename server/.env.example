# Google Cloud project with Vertex AI enabled
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Model to use for generation
GEMINI_MODEL=gemini-omni-flash-preview

# --- LOCAL DEV AUTH ---
# Easiest: gcloud Application Default Credentials
#   gcloud auth application-default login
# Then leave everything below unset.
#
# Optional key-file path (only if your org allows key creation):
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- VERCEL / PRODUCTION AUTH (keyless, Workload Identity Federation) ---
# No JSON key is used. Set these in the Vercel dashboard (not here) and enable
# Vercel OIDC for the project. Listed here for reference:
# GCP_PROJECT_NUMBER=921358658147
# GCP_SERVICE_ACCOUNT_EMAIL=vercel-vertex@your-project.iam.gserviceaccount.com
# GCP_WORKLOAD_IDENTITY_POOL_ID=vercel
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=vercel

# Server port
PORT=8787

# Comma-separated list of allowed origins for CORS (client dev server)
CLIENT_ORIGIN=http://localhost:5173
