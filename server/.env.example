# Google Cloud project with Vertex AI enabled
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# NOTE: model ids are hardcoded in server/src/gemini.ts (video:
# gemini-omni-flash-preview) and server/src/chatGemini.ts (chat:
# gemini-3.5-flash). They are intentionally NOT env vars — a stale
# GEMINI_MODEL value in Vercel once broke generation with a 400.

# --- LOCAL DEV AUTH ---
# Easiest: gcloud Application Default Credentials
#   gcloud auth application-default login
# Then leave everything below unset.
#
# Optional key-file path (only if your org allows key creation):
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- VERCEL / PRODUCTION AUTH (keyless, Workload Identity Federation) ---
# No JSON key is used. Set these in the Vercel dashboard (not here) and enable
# Vercel OIDC for the project. Listed here for reference:
# GCP_PROJECT_NUMBER=921358658147
# GCP_SERVICE_ACCOUNT_EMAIL=vercel-vertex@your-project.iam.gserviceaccount.com
# GCP_WORKLOAD_IDENTITY_POOL_ID=vercel
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=vercel

# Server port
PORT=8787

# Comma-separated list of allowed origins for CORS (client dev server)
CLIENT_ORIGIN=http://localhost:5173

# --- HOSTED VIDEO LINKS (MCP tool) ---
# The MCP generate_video tool hosts videos via Vercel Blob and returns a link
# under this base URL: PUBLIC_BASE_URL/videos/<id>. In production this should
# be your real domain. BLOB_READ_WRITE_TOKEN is auto-injected by Vercel once
# a Blob store is attached (Storage -> Create Database -> Blob) — do not set
# it manually. Without a Blob store configured, the tool falls back to
# embedding video bytes directly instead of hosting a link.
PUBLIC_BASE_URL=https://motion.nanoni.studio

# --- CHAT ---
# Chat runs through the same Vertex AI project/auth as Omni above (gcloud ADC
# locally, Workload Identity Federation on Vercel) — no separate API key, and
# the chat model is hardcoded in code (see note at the top of this file).
