# --- ATTACHMENTS (chat file uploads) ---
# Files attach directly to Cloudinary from the browser (unsigned upload),
# bypassing Vercel's ~4.5MB serverless function request body limit. Create a
# free account at cloudinary.com, then:
#   1. Copy your "Cloud name" from the dashboard.
#   2. Settings -> Upload -> Upload presets -> Add upload preset -> set
#      Signing Mode to "Unsigned" -> save, then copy its name.
# Neither value is a secret (the preset only grants upload, not read/delete),
# so it's safe to ship in the client bundle. Set both in Vercel project
# settings too (Production + Preview) so the deployed build has them.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-name
